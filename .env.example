# Environment Configuration Template
# Copy this file to create environment-specific configurations:
# - .env.development (for local development)
# - .env.staging (for staging environment)
# - .env.production (for production - set values in Vercel dashboard)
# - .env.local (for personal local overrides - gitignored)
#
# Environment File Load Order (highest priority first):
# 1. .env.$(NODE_ENV).local (e.g., .env.development.local)
# 2. .env.local
# 3. .env.$(NODE_ENV) (e.g., .env.development)
# 4. .env

# ============================================================================
# DATABASE
# ============================================================================
# Supabase PostgreSQL connection string
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# For development: Direct connection (port 5432)
# For production: Add ?pgbouncer=true&connection_limit=1 for connection pooling
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ============================================================================
# AUTHENTICATION (NextAuth.js)
# ============================================================================
# Your app's URL
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Authentication secret for JWT signing and token verification
# Generate with: openssl rand -base64 32
# IMPORTANT: Use different secrets for dev/staging/production
# AUTH_SECRET is required by NextAuth v5 — set both to the same value
NEXTAUTH_SECRET=your-secret-key-here
AUTH_SECRET=your-secret-key-here

# ============================================================================
# EMAIL SERVICE (Resend)
# ============================================================================
# Resend API Key
# Get from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
# Development: Use test key (onboarding@resend.dev domain)
# Production: Use production key with verified domain
RESEND_API_KEY=re_xxxxxxxxxxxxx

# From email address
# Development: "App Name <onboarding@resend.dev>"
# Production: "App Name <noreply@yourdomain.com>" (requires domain verification)
EMAIL_FROM=Riff <onboarding@resend.dev>

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Set to 'development', 'staging', or 'production'
NODE_ENV=development
