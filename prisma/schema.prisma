generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER ====================

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  emailVerified      DateTime?
  password           String?            // Hashed password for credentials auth
  name               String?            // Made optional for magic link auth
  username           String?            @unique // Made optional for magic link auth
  firstName          String?            // New: First name collected during onboarding
  lastName           String?            // New: Last name collected during onboarding
  bio                String?
  avatarUrl          String?
  lastActiveClubId   String?            // New: Tracks last viewed club for redirect
  onboardingStep     OnboardingStep?    // New: Resume onboarding progress
  onboardingCompleted Boolean           @default(false) // New: Track if user finished onboarding
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations (updated for Clubs/Riffs)
  clubMemberships          ClubMember[]
  createdClubs             Club[]                   @relation("ClubCreator")
  moderatedClubs           Club[]                   @relation("ClubModerator")
  createdRiffs             Riff[]                   @relation("RiffCreator")
  riffParticipations       RiffParticipant[]
  pieces                   Piece[]
  individualShares         Share[]                  @relation("IndividualShares")
  comments                 Comment[]
  ownedCollections         Collection[]             @relation("CollectionOwner")
  addedPiecesToCollection  CollectionPiece[]
  collectionCollaborations CollectionCollaborator[]
  sentNotifications        Notification[]           @relation("NotificationActor")
  receivedNotifications    Notification[]           @relation("NotificationRecipient")
  createdInvites           ClubInvite[]             // New: Club invites created by user
  pieceReads               PieceRead[]              // New: Track which pieces user has read

  // DEPRECATED: Circle relations (kept for backward compatibility)
  circleMemberships        CircleMember[]
  createdCircles           Circle[]                 @relation("CircleCreator")
  createdPrompts           CirclePrompt[]

  @@map("users")
}

enum OnboardingStep {
  NAME          // Collecting first/last name
  CLUB_CHOICE   // Choosing to start or join a club
  INVITE        // Inviting friends to club (club already created)
  COMPLETED     // Onboarding finished
}

// ==================== CLUBS (NEW ARCHITECTURE) ====================

model Club {
  id          String   @id @default(cuid())
  name        String
  description String?
  bannerImage String?  // New: Banner image URL for club personalization
  isArchived  Boolean  @default(false)
  adminId     String   // Creator, permanent
  moderatorId String?  // Rotatable moderator role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  admin       User         @relation("ClubCreator", fields: [adminId], references: [id], onDelete: Cascade)
  moderator   User?        @relation("ClubModerator", fields: [moderatorId], references: [id], onDelete: SetNull)
  members     ClubMember[]
  riffs       Riff[]
  shares      Share[]
  collections Collection[]
  comments    Comment[]
  notifications Notification[]
  invites     ClubInvite[] // New: Club invitation tokens

  @@map("clubs")
}

// ==================== CIRCLE (DEPRECATED - TO BE REMOVED) ====================

model Circle {
  id          String   @id @default(cuid())
  name        String
  description String?
  isArchived  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  createdBy   User           @relation("CircleCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     CircleMember[]
  prompts     CirclePrompt[]
  pieces      PieceShare[]
  collections_deprecated Collection[] @relation("DeprecatedCircleCollections")
  comments_deprecated    Comment[]    @relation("DeprecatedCircleComments")
  notifications_deprecated Notification[] @relation("DeprecatedCircleNotifications")

  @@map("circles_deprecated")
}

model ClubMember {
  id           String    @id @default(cuid())
  clubId       String
  userId       String
  role         ClubRole  @default(MEMBER)
  joinedAt     DateTime  @default(now())
  lastViewedAt DateTime? // New: Track last time user viewed this club

  // Relations
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([userId, lastViewedAt]) // New: Index for efficient "last active club" queries
  @@map("club_members")
}

enum ClubRole {
  ADMIN      // Creator, permanent
  MODERATOR  // Rotatable between members
  MEMBER     // Default role
}

// ==================== RIFFS (NEW ARCHITECTURE) ====================

model Riff {
  id          String     @id @default(cuid())
  clubId      String
  creatorId   String
  title        String?
  prompt       String?    @db.Text
  deadline     DateTime?
  status       RiffStatus @default(DRAFT)
  volumeNumber Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  club         Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator      User              @relation("RiffCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants RiffParticipant[]
  pieces       PieceRiff[]
  pieceReads   PieceRead[]
  shares       Share[]
  comments     Comment[]
  notifications Notification[]

  @@map("riffs")
}

enum RiffStatus {
  DRAFT      // Creator is setting up, no invites sent yet
  ACTIVE     // Running, members can join/leave and submit pieces
  REVEALED   // Host revealed, members can now read pieces
  COMPLETED  // Manually marked complete by any club member
}

model RiffParticipant {
  id        String   @id @default(cuid())
  riffId    String
  userId    String
  joinedAt  DateTime @default(now())

  // Relations
  riff Riff @relation(fields: [riffId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([riffId, userId])
  @@map("riff_participants")
}

// ==================== PIECE READS (REVEAL TRACKING) ====================

model PieceRead {
  id        String   @id @default(cuid())
  userId    String
  pieceId   String
  riffId    String
  readAt    DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  piece Piece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  riff  Riff  @relation(fields: [riffId], references: [id], onDelete: Cascade)

  @@unique([userId, pieceId, riffId])
  @@map("piece_reads")
}

// ==================== CIRCLE MEMBERS (DEPRECATED) ====================

model CircleMember {
  id       String           @id @default(cuid())
  circleId String
  userId   String
  role     CircleMemberRole @default(MEMBER)
  joinedAt DateTime         @default(now())

  // Relations
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@map("circle_members_deprecated")
}

enum CircleMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ==================== CIRCLE PROMPTS ====================

model CirclePrompt {
  id             String                @id @default(cuid())
  circleId       String
  title          String
  description    String?
  isFreeform     Boolean               @default(false)
  deadline       DateTime?
  visibilityRule PromptVisibilityRule  @default(ON_SUBMIT)
  createdById    String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  // Relations
  circle    Circle       @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  pieces    PieceShare[]

  @@map("circle_prompts")
}

enum PromptVisibilityRule {
  ON_SUBMIT
  ALL_SUBMITTED
  AFTER_DEADLINE
}

// ==================== PIECE & VERSIONS ====================

model Piece {
  id             String   @id @default(cuid())
  title          String
  subtitle       String?
  authorId       String
  currentContent String   @db.Text
  currentExcerpt String?
  coverImage     String?  // Cover image URL for piece display (uploaded later)
  wordCount      Int      @default(0)
  readLengthMin  Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  author     User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions   PieceVersion[]
  newShares  Share[]           // NEW: Multi-level sharing (club, riff, individual, public)
  shares     PieceShare[]      // DEPRECATED: Old circle-based sharing
  riffs      PieceRiff[]       // NEW: Junction for piece-riff relationships
  pieceReads PieceRead[]       // NEW: Track which users have read this piece
  collections CollectionPiece[]
  visibility PieceVisibilitySettings?
  comments   Comment[]
  notifications Notification[]

  @@map("pieces")
}

model PieceVersion {
  id            String   @id @default(cuid())
  pieceId       String
  versionNumber Int
  title         String
  content       String   @db.Text
  excerpt       String?
  createdAt     DateTime @default(now())

  // Relations
  piece      Piece        @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  newShares  Share[]      // NEW: Multi-level sharing
  shares     PieceShare[] // DEPRECATED
  riffs      PieceRiff[]  // NEW: Junction for riff submissions
  comments   Comment[]

  @@unique([pieceId, versionNumber])
  @@map("piece_versions")
}

// ==================== PIECE-RIFF JUNCTION (NEW) ====================

model PieceRiff {
  id          String   @id @default(cuid())
  pieceId     String
  riffId      String
  versionId   String?   // Optional: specific version submitted to riff
  submittedAt DateTime? // Null = attached but not finalized, non-null = submitted and ready for reveal

  // Relations
  piece   Piece         @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  riff    Riff          @relation(fields: [riffId], references: [id], onDelete: Cascade)
  version PieceVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@unique([pieceId, riffId])
  @@map("piece_riffs")
}

// ==================== SHARES (NEW ARCHITECTURE) ====================

model Share {
  id              String    @id @default(cuid())
  pieceId         String
  versionId       String
  shareType       ShareType
  clubId          String?   // For CLUB-level shares
  riffId          String?   // For RIFF-level shares
  sharedWithId    String?   // For INDIVIDUAL shares
  isPublic        Boolean   @default(false)  // For PUBLIC shares
  submittedAt     DateTime  @default(now())
  isVisible       Boolean   @default(true)

  // Relations
  piece        Piece         @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  version      PieceVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  club         Club?         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  riff         Riff?         @relation(fields: [riffId], references: [id], onDelete: Cascade)
  sharedWith   User?         @relation("IndividualShares", fields: [sharedWithId], references: [id], onDelete: Cascade)

  @@map("shares")
}

enum ShareType {
  CLUB        // All club members can see
  RIFF        // Only riff participants can see
  INDIVIDUAL  // Specific user only
  PUBLIC      // Anyone with link (view-only, no comments)
}

// ==================== PIECE SHARES (DEPRECATED) ====================

model PieceShare {
  id          String   @id @default(cuid())
  pieceId     String
  circleId    String
  versionId   String
  promptId    String?
  submittedAt DateTime @default(now())
  isVisible   Boolean  @default(true)

  // Relations
  piece   Piece         @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  circle  Circle        @relation(fields: [circleId], references: [id], onDelete: Cascade)
  version PieceVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  prompt  CirclePrompt? @relation(fields: [promptId], references: [id], onDelete: SetNull)

  @@unique([pieceId, circleId])
  @@map("piece_shares_deprecated")
}

// ==================== PIECE VISIBILITY ====================

model PieceVisibilitySettings {
  id             String          @id @default(cuid())
  pieceId        String          @unique
  visibility     PieceVisibility @default(PRIVATE)
  allowedUserIds String[]

  // Relations
  piece Piece @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@map("piece_visibility_settings")
}

enum PieceVisibility {
  PRIVATE
  CIRCLES_ONLY
  SPECIFIC_USERS
  PUBLIC
}

// ==================== COMMENTS ====================

model Comment {
  id             String   @id @default(cuid())
  content        String   @db.Text
  pieceId        String
  versionId      String?  // Optional: no longer required for new riff-scoped comments
  clubId         String?  // NEW: Club context for comments
  riffId         String?  // NEW: Riff context for comments
  circleId       String?  // DEPRECATED: Old circle context
  authorId       String
  parentId       String?
  selectionStart Int?
  selectionEnd   Int?
  selectedText   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  author            User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  piece             Piece         @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  version           PieceVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)
  club              Club?         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  riff              Riff?         @relation(fields: [riffId], references: [id], onDelete: Cascade)
  circle_deprecated Circle?       @relation("DeprecatedCircleComments", fields: [circleId], references: [id], onDelete: Cascade)
  parent            Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies           Comment[]     @relation("CommentReplies")
  notifications     Notification[]

  @@map("comments")
}

// ==================== COLLECTIONS ====================

model Collection {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        CollectionType @default(PERSONAL)
  ownerId     String
  clubId      String?        // NEW: Club collections
  circleId    String?        // DEPRECATED: Old circle collections
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  owner                  User                     @relation("CollectionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  club                   Club?                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  circle_deprecated      Circle?                  @relation("DeprecatedCircleCollections", fields: [circleId], references: [id], onDelete: Cascade)
  pieces                 CollectionPiece[]
  collaborators          CollectionCollaborator[]
  notifications          Notification[]

  @@map("collections")
}

model CollectionPiece {
  id           String   @id @default(cuid())
  collectionId String
  pieceId      String
  addedById    String
  addedAt      DateTime @default(now())
  order        Int?

  // Relations
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  piece      Piece      @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  addedBy    User       @relation(fields: [addedById], references: [id], onDelete: Cascade)

  @@unique([collectionId, pieceId])
  @@map("collection_pieces")
}

model CollectionCollaborator {
  id           String   @id @default(cuid())
  collectionId String
  userId       String
  canEdit      Boolean  @default(false)
  addedAt      DateTime @default(now())

  // Relations
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId])
  @@map("collection_collaborators")
}

enum CollectionType {
  PERSONAL
  GROUP
  CLUB    // NEW: Club-based collections
  CIRCLE  // DEPRECATED
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id           String           @id @default(cuid())
  type         NotificationType
  recipientId  String
  actorId      String?
  clubId       String?          // NEW: Club notifications
  riffId       String?          // NEW: Riff notifications
  circleId     String?          // DEPRECATED: Old circle notifications
  pieceId      String?
  commentId    String?
  collectionId String?
  isRead       Boolean          @default(false)
  createdAt    DateTime         @default(now())

  // Relations
  recipient          User        @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor              User?       @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  club               Club?       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  riff               Riff?       @relation(fields: [riffId], references: [id], onDelete: Cascade)
  circle_deprecated  Circle?     @relation("DeprecatedCircleNotifications", fields: [circleId], references: [id], onDelete: Cascade)
  piece              Piece?      @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  comment            Comment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  collection         Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  // NEW: Club/Riff notifications
  CLUB_INVITATION
  RIFF_CREATED
  RIFF_INVITATION
  RIFF_STARTED
  RIFF_DEADLINE_APPROACHING
  RIFF_COMPLETED
  RIFF_DEADLINE_CHANGED
  ALL_PIECES_SUBMITTED
  PIECE_SUBMITTED_TO_RIFF
  CLUB_MEMBER_JOINED

  // Comment notifications
  NEW_COMMENT
  COMMENT_REPLY

  // Collection notifications
  COLLECTION_INVITE
  PIECE_ADDED_TO_COLLECTION

  // DEPRECATED: Old circle notifications
  CIRCLE_INVITATION
  NEW_PROMPT
  PIECE_SUBMITTED
  PIECES_VISIBLE
}

// ==================== NEXTAUTH ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== CLUB INVITES (NEW) ====================

model ClubInvite {
  id        String    @id @default(cuid())
  clubId    String
  token     String    @unique // Unique token for shareable invite link
  createdBy String    // User who created the invite
  expiresAt DateTime  // Invite expiry (7 days default)
  usedAt    DateTime? // Timestamp when invite was used
  usedBy    String?   // User ID who used the invite
  createdAt DateTime  @default(now())

  // Relations
  club    Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([token]) // Index for fast invite lookup
  @@index([clubId]) // Index for club's invites
  @@map("club_invites")
}
