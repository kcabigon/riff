{
  "name": "riff",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev --webpack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "db:migrate:dev": "dotenv -e .env.development -- npx prisma migrate dev",
    "db:migrate:staging": "dotenv -e .env.staging -- npx prisma migrate deploy",
    "db:migrate:prod": "dotenv -e .env.production -- npx prisma migrate deploy",
    "db:seed:dev": "dotenv -e .env.development -- npx prisma db seed",
    "db:studio:dev": "dotenv -e .env.development -- npx prisma studio --port 5555",
    "db:studio:staging": "dotenv -e .env.staging -- npx prisma studio --port 5556",
    "db:generate": "npx prisma generate",
    "db:seed": "dotenv -- npx prisma db seed",
    "db:reset:e2e": "dotenv -e .env.development -- tsx scripts/reset-e2e.ts",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx scripts/seed-e2e.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tiptap/extension-character-count": "^3.11.1",
    "@tiptap/extension-image": "^3.11.1",
    "@tiptap/extension-link": "^3.11.1",
    "@tiptap/extension-placeholder": "^3.11.1",
    "@tiptap/extension-text-align": "^3.11.1",
    "@tiptap/extension-youtube": "^3.11.1",
    "@tiptap/pm": "^3.11.1",
    "@tiptap/react": "^3.11.1",
    "@tiptap/starter-kit": "^3.11.1",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "docx": "^9.6.1",
    "domhandler": "^5.0.3",
    "framer-motion": "^12.38.0",
    "heic2any": "^0.0.4",
    "htmlparser2": "^8.0.2",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "next": "^16.0.7",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-easy-crop": "^5.5.6",
    "resend": "^4.8.0",
    "tiptap-extension-resize-image": "^1.3.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.1.0",
    "tailwindcss": "^4.0.0",
    "prisma": "^6.1.0",
    "typescript": "^5"
  }
}
