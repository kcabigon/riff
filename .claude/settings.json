{
  "permissions": {
    "allow": [
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(npm run lint)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "mcp__github__pull_request_read",
      "mcp__github__list_pull_requests",
      "mcp__github__search_pull_requests",
      "mcp__github__list_issues",
      "mcp__github__list_commits",
      "mcp__github__get_commit",
      "mcp__github__actions_list"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push origin --force*)",
      "Bash(git reset --hard* main*)",
      "Bash(git reset --hard* develop*)",
      "Bash(git reset --hard* staging*)",
      "Bash(git checkout main && git commit*)",
      "Bash(git checkout develop && git commit*)",
      "Bash(git checkout staging && git commit*)",
      "Bash(prisma migrate reset*)",
      "Bash(prisma db push --force-reset*)",
      "Bash(prisma db push --accept-data-loss*)",
      "Bash(*--force-reset*)",
      "Bash(*--accept-data-loss*)"
    ]
  }
}
